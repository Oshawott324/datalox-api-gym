{
  "name": "datalox-api-gym",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Resettable, verifiable API worlds for agent practice, replay evidence, and training/eval export.",
  "main": "./dist/src/sdk/index.js",
  "types": "./dist/src/sdk/index.d.ts",
  "exports": {
    ".": "./dist/src/sdk/index.js",
    "./sdk": "./dist/src/sdk/index.js"
  },
  "bin": {
    "datalox": "./bin/datalox.js",
    "datalox-mcp": "./bin/datalox-mcp.js",
    "datalox-api-gym": "./bin/datalox-mcp.js",
    "datalox-api-gym-mcp": "./bin/datalox-api-gym-mcp.js",
    "datalox-claude": "./bin/datalox-claude.js",
    "datalox-codex": "./bin/datalox-codex.js",
    "datalox-wrap": "./bin/datalox-wrap.js"
  },
  "scripts": {
    "build": "tsc",
    "datalox": "node dist/src/cli/main.js",
    "demo:verified-replay": "npm run build && node examples/verified-replay-quickstart/run-demo.mjs",
    "mcp:stdio": "node dist/src/mcp/replayServer.js",
    "mcp:full": "node dist/src/mcp/server.js",
    "prepare": "tsc",
    "check": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "vitest run tests"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "ajv": "^8.18.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.59.1",
    "zod": "^4.3.6"
  }
}
