{
  "name": "datalox-trajectory-mcp",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Trajectory-focused Datalox MCP for verified debugging trajectory data and eval export.",
  "bin": {
    "datalox": "./bin/datalox.js",
    "datalox-mcp": "./bin/datalox-mcp.js",
    "datalox-trajectory-mcp": "./bin/datalox-mcp.js",
    "datalox-pack-mcp": "./bin/datalox-pack-mcp.js",
    "datalox-claude": "./bin/datalox-claude.js",
    "datalox-codex": "./bin/datalox-codex.js",
    "datalox-wrap": "./bin/datalox-wrap.js"
  },
  "scripts": {
    "agent:bootstrap": "node scripts/agent-bootstrap.mjs",
    "agent:resolve": "node scripts/agent-resolve.mjs",
    "agent:lint": "node scripts/agent-lint.mjs",
    "agent:learn-pattern": "node scripts/agent-learn-pattern.mjs",
    "agent:learn-skill": "node scripts/agent-learn-skill.mjs",
    "agent:learn-from-interaction": "node scripts/agent-learn-from-interaction.mjs",
    "demo:one-correction": "node scripts/demo-one-correction.mjs",
    "demo:one-correction:artifact": "node scripts/demo-one-correction-artifact.mjs",
    "demo:one-correction:replay": "node scripts/demo-one-correction-replay.mjs",
    "build": "tsc",
    "datalox": "node dist/src/cli/main.js",
    "mcp:stdio": "node dist/src/mcp/trajectoryServer.js",
    "mcp:full": "node dist/src/mcp/server.js",
    "prepare": "tsc",
    "check": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "vitest run tests"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.59.1",
    "zod": "^4.3.6"
  }
}
