{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lab Campaign Ops Source Pack",
  "type": "object",
  "required": [
    "schema_version",
    "source_pack_id",
    "provider",
    "role",
    "source_status",
    "evidence_urls",
    "tools",
    "fixtures",
    "dry_run_semantics",
    "live_boundary",
    "allowed_errors",
    "source_gaps"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "greenfield_lab_campaign_ops.source_pack.v0"
    },
    "source_pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+_v[0-9]+$"
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "source_status": {
      "enum": [
        "source_grounded",
        "domain_reviewed",
        "speculative_calibration_only"
      ]
    },
    "evidence_urls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "url", "evidence_type"],
        "additionalProperties": false,
        "properties": {
          "label": {"type": "string", "minLength": 1},
          "url": {"type": "string", "format": "uri"},
          "evidence_type": {
            "enum": [
              "openapi_reference",
              "api_reference",
              "developer_guide",
              "simulation_docs",
              "examples_repository"
            ]
          }
        }
      }
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "tool_id",
          "operation",
          "source_refs",
          "dry_run_behavior",
          "writes_sandbox_state"
        ],
        "additionalProperties": false,
        "properties": {
          "tool_id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "operation": {
            "type": "string",
            "minLength": 1
          },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "fixture_refs": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "dry_run_behavior": {
            "type": "string",
            "minLength": 1
          },
          "writes_sandbox_state": {
            "type": "boolean"
          }
        }
      }
    },
    "fixtures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fixture_id", "path", "fixture_status", "source_refs"],
        "additionalProperties": false,
        "properties": {
          "fixture_id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "fixture_status": {
            "enum": [
              "source_copied_example",
              "derived_from_source_example",
              "speculative_fixture_for_schema_exercise"
            ]
          },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "dry_run_semantics": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "live_boundary": {
      "type": "object",
      "required": ["forbidden_actions", "boundary_statement"],
      "additionalProperties": false,
      "properties": {
        "forbidden_actions": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "boundary_statement": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "allowed_errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "meaning"],
        "additionalProperties": false,
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[A-Z0-9_]+$"
          },
          "meaning": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source_gaps": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  }
}
