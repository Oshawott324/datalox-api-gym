{"id":"operation:refundPayment","source_pack_id":"api.square.2026-06-12","operation_id":"refundPayment","method":"POST","path":"/v2/refunds","summary":"Refund a Square payment or record a refund.","source_refs":[{"kind":"docs","url":"https://developer.squareup.com/reference/square/refunds-api/refund-payment"}],"request_fields":[{"name":"idempotency_key","type":"string","required":true},{"name":"amount_money","type":"object","required":true},{"name":"payment_id","type":"string","required":false},{"name":"destination_id","type":"string","required":false},{"name":"unlinked","type":"boolean","required":false},{"name":"location_id","type":"string","required":false},{"name":"customer_id","type":"string","required":false},{"name":"reason","type":"string","required":false}],"agent_notes":["Docs state amount_money cannot exceed payment total_money minus completed refunds.","Docs state payment_id is required for linked refunds when unlinked is false, while destination_id and location_id are required for unlinked refunds."]}
{"id":"operation:createInvoice","source_pack_id":"api.square.2026-06-12","operation_id":"createInvoice","method":"POST","path":"/v2/invoices","summary":"Create a draft Square invoice for an order created using Orders API.","source_refs":[{"kind":"docs","url":"https://developer.squareup.com/reference/square/invoices-api/create-invoice"},{"kind":"docs","url":"https://developer.squareup.com/docs/invoices-api/overview"}],"request_fields":[{"name":"invoice","type":"object","required":true},{"name":"idempotency_key","type":"string","required":false},{"name":"invoice.location_id","type":"string","required":false},{"name":"invoice.order_id","type":"string","required":false},{"name":"invoice.primary_recipient.customer_id","type":"string","required":false},{"name":"invoice.payment_requests","type":"array","required":false}],"agent_notes":["Docs state a draft invoice takes no action until it is published.","Docs state invoices created with the Invoices API must be associated with an order created using Orders API."]}
{"id":"operation:createSubscription","source_pack_id":"api.square.2026-06-12","operation_id":"createSubscription","method":"POST","path":"/v2/subscriptions","summary":"Enroll a Square customer in a subscription.","source_refs":[{"kind":"docs","url":"https://developer.squareup.com/reference/square/subscriptions-api/create-subscription"}],"request_fields":[{"name":"idempotency_key","type":"string","required":false},{"name":"location_id","type":"string","required":true},{"name":"plan_variation_id","type":"string","required":false},{"name":"customer_id","type":"string","required":true},{"name":"start_date","type":"string","required":false},{"name":"card_id","type":"string","required":false},{"name":"timezone","type":"string","required":false},{"name":"phases","type":"array","required":false}],"agent_notes":["Docs state Square charges the card if card_id is provided; otherwise Square sends an invoice to the customer's email address.","Docs state the subscription starts immediately unless start_date is supplied."]}
