{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "datalox_world_spec.v0",
  "type": "object",
  "required": ["schema_version", "world_id", "driver", "tool_catalog"],
  "properties": {
    "schema_version": {"const": "datalox_world_spec.v0"},
    "world_id": {"type": "string"},
    "name": {"type": "string"},
    "description": {"type": "string"},
    "driver": {"type": "object"},
    "tool_catalog": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["description", "input_schema"],
        "properties": {
          "description": {"type": "string"},
          "input_schema": {"type": "object"}
        }
      }
    }
  }
}
