{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://datalox.local/schemas/env-data-proof-v0/verifier-result.schema.json",
  "title": "Datalox Env Data Proof Verifier Result",
  "description": "Deterministic verifier result for one seed-task answer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "family",
    "answer_path",
    "passed",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "const": "agent_native_seed_verifier_result.v0"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "family": {
      "type": "string",
      "enum": [
        "flowcyto",
        "molecule-biology",
        "protein-mcp"
      ]
    },
    "answer_path": {
      "type": "string",
      "minLength": 1
    },
    "passed": {
      "type": "boolean"
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "passed",
          "message"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "passed": {
            "type": "boolean"
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "expected": {},
          "actual": {}
        }
      }
    }
  }
}
