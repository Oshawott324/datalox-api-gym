{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://datalox.local/schemas/env-data-proof-v0/sft-chat-row.schema.json",
  "title": "Datalox Env Data Proof SFT Chat Row",
  "description": "One train-split chat SFT row derived from verifier-passing replay evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "family",
    "split",
    "messages",
    "source_answer_path",
    "verifier_spec_path",
    "observation_path",
    "split_metadata_path",
    "evidence_ids",
    "model_context",
    "export_gate"
  ],
  "properties": {
    "schema_version": {
      "const": "agent_native_seed_sft_chat_row.v0"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "family": {
      "type": "string",
      "enum": [
        "flowcyto",
        "molecule-biology",
        "scientific-data-qc"
      ]
    },
    "split": {
      "const": "train"
    },
    "messages": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "system",
              "user",
              "assistant"
            ]
          },
          "content": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source_answer_path": {
      "type": "string",
      "minLength": 1
    },
    "verifier_spec_path": {
      "type": "string",
      "minLength": 1
    },
    "observation_path": {
      "type": "string",
      "minLength": 1
    },
    "split_metadata_path": {
      "type": "string",
      "minLength": 1
    },
    "evidence_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "model_context": {
      "type": "object"
    },
    "export_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed",
        "redaction"
      ],
      "properties": {
        "allowed": {
          "const": true
        },
        "redaction": {
          "const": "none_needed"
        }
      }
    }
  }
}
