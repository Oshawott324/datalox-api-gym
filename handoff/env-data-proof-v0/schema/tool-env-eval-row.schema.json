{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://datalox.local/schemas/env-data-proof-v0/tool-env-eval-row.schema.json",
  "title": "Datalox Env Data Proof Tool Environment Eval Row",
  "description": "One eval row for a tool-using agent environment. Unlike context eval rows, this row does not preload replay observations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "family",
    "split",
    "eval_mode",
    "runtime_kind",
    "messages",
    "allowed_tools",
    "forbidden_tools",
    "expected_tool_path",
    "output_schema_path",
    "family_output_schema_path",
    "verifier_spec_path",
    "split_metadata_path",
    "source_task_spec_path"
  ],
  "properties": {
    "schema_version": {
      "const": "agent_native_seed_tool_env_eval_row.v0"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "family": {
      "type": "string",
      "enum": [
        "flowcyto",
        "molecule-biology",
        "protein-mcp"
      ]
    },
    "split": {
      "type": "string",
      "enum": [
        "train",
        "dev",
        "test"
      ]
    },
    "eval_mode": {
      "const": "tool_env"
    },
    "runtime_kind": {
      "type": "string",
      "enum": [
        "sibling_domain_tool_runtime"
      ]
    },
    "messages": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "system",
              "user"
            ]
          },
          "content": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "allowed_tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_tools": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_tool_path": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "output_schema_path": {
      "type": "string",
      "minLength": 1
    },
    "family_output_schema_path": {
      "type": "string",
      "minLength": 1
    },
    "verifier_spec_path": {
      "type": "string",
      "minLength": 1
    },
    "split_metadata_path": {
      "type": "string",
      "minLength": 1
    },
    "source_task_spec_path": {
      "type": "string",
      "minLength": 1
    }
  }
}
