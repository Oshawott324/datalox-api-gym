{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://datalox.local/schemas/env-data-proof-v0/task-output.schema.json",
  "title": "Datalox Env Data Proof Task Output",
  "description": "Shared structured output envelope for multi-family agent-native scientific workflow tasks used in the env-data-proof-v0 handoff.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "family",
    "diagnosis",
    "evidence_ids",
    "next_action",
    "missing_fields",
    "forbidden_actions_avoided",
    "family_output"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "family": {
      "type": "string",
      "enum": [
        "flowcyto",
        "molecule-biology",
        "scientific-data-qc",
        "workflow-debug"
      ]
    },
    "diagnosis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class",
        "summary"
      ],
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "flowcyto_report_pass",
            "flowcyto_revision_recovery",
            "flowcyto_report_recovery",
            "flowcyto_metadata_decision",
            "molecule_context_decision",
            "molecule_feature_annotation",
            "molecule_primer_decision",
            "molecule_digest_decision",
            "molecule_pcr_decision",
            "fastq_qc_decision",
            "single_cell_qc_decision",
            "protein_structure_prep_decision",
            "workflow_result_qc_decision",
            "ci_failure_root_cause",
            "dependency_upgrade_regression",
            "flaky_test",
            "real_regression",
            "duplicate_issue",
            "security_dependency_alert",
            "support_escalation",
            "insufficient_evidence"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(tool_io|replay_bundle|task|source|log|doc|issue|pr|check|run|advisory|policy|metric|sample|file|channel|marker|matrix|cell|gene|chain|ligand|structure|workspace|gate|stats|qc|report|molecule|feature|primer|digest|pcr)[:/][A-Za-z0-9._:@#/?=-]+$"
      }
    },
    "next_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "summary"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "submit_report",
            "repair_report",
            "repair_revision",
            "repair_metadata",
            "validate_workspace",
            "annotate_feature",
            "upsert_primer",
            "simulate_digest",
            "simulate_pcr",
            "export_genbank",
            "trim_or_filter_reads",
            "exclude_sample",
            "prepare_structure",
            "rerun_analysis",
            "fix",
            "ask_for_missing_data",
            "escalate",
            "retry_or_rerun",
            "close_as_duplicate",
            "mark_flaky",
            "mark_insufficient_evidence",
            "no_action"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "missing_fields": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "enum": [
          "workspace_path",
          "workspace_revision",
          "sample_id",
          "gate_id",
          "stats_ref",
          "qc_ref",
          "report_field",
          "molecule_id",
          "sequence_context",
          "feature_id",
          "primer_id",
          "digest_result",
          "pcr_result",
          "computed_metric",
          "advisory_id",
          "affected_package",
          "customer_id",
          "dependency_path",
          "duplicate_issue_id",
          "event_id",
          "failing_job",
          "failing_test",
          "key_log_line",
          "maintainer_decision",
          "package_version",
          "policy_citation",
          "rerun_history",
          "reproduction_steps",
          "source_artifact"
        ]
      }
    },
    "forbidden_actions_avoided": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "enum": [
          "patched_workspace_json_directly",
          "skipped_required_tool",
          "submitted_report_without_evidence",
          "used_stale_revision",
          "claimed_plot_without_stats",
          "inferred_sequence_from_prose",
          "claimed_digest_without_tool_evidence",
          "claimed_pcr_without_tool_evidence",
          "copied_unreviewed_raw_artifact",
          "called_live_service",
          "claimed_live_state",
          "closed_issue_without_evidence",
          "ignored_replay_miss",
          "invented_status",
          "mutated_external_state",
          "promised_customer_refund",
          "promised_unverified_fix",
          "used_uncited_evidence"
        ]
      }
    },
    "family_output": {
      "type": "object",
      "description": "Family-specific structured payload validated by the task family's stricter schema or verifier.",
      "minProperties": 1
    }
  }
}
