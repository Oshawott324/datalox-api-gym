{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://datalox.local/schemas/env-data-proof-v0/agent-visible-tool-observation.schema.json",
  "title": "Datalox Env Data Proof Agent-Visible Tool Observation",
  "description": "One captured agent-visible tool request and observation for seed-task handoff validation before canonical tool_io_record.v1 conversion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "family",
    "sequence_index",
    "tool_name",
    "request",
    "observation",
    "workspace_revision",
    "evidence_ids",
    "capture_source",
    "captured_at"
  ],
  "properties": {
    "schema_version": {
      "const": "agent_visible_tool_observation.v0"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "family": {
      "type": "string",
      "enum": [
        "flowcyto",
        "molecule-biology",
        "protein-mcp"
      ]
    },
    "sequence_index": {
      "type": "integer",
      "minimum": 0
    },
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "request": {
      "type": "object"
    },
    "observation": {},
    "workspace_revision": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "evidence_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(tool_io|source|file|metric|run|workspace|gate|stats|qc|report|molecule|feature|primer|digest|pcr)[:/][A-Za-z0-9._:@#/?=-]+$"
      }
    },
    "capture_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "live_domain_tool",
            "existing_deterministic_fixture_observation"
          ]
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "source_path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "captured_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T"
    }
  }
}
