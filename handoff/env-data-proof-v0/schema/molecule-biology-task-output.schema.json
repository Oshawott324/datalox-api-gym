{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://datalox.local/schemas/env-data-proof-v0/molecule-biology-task-output.schema.json",
  "title": "Datalox Env Data Proof Molecule Biology Task Output Payload",
  "description": "Family-specific payload for deterministic sequence workspace tasks.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workspace_path",
    "workspace_revision",
    "molecule_id",
    "operation",
    "tool_result_refs"
  ],
  "properties": {
    "workspace_path": {
      "type": "string",
      "minLength": 1
    },
    "workspace_revision": {
      "type": "integer",
      "minimum": 0
    },
    "molecule_id": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "type": "string",
      "enum": [
        "sequence_context",
        "feature_annotation",
        "primer_validation",
        "restriction_digest",
        "pcr_simulation",
        "genbank_export",
        "insufficient_evidence"
      ]
    },
    "tool_result_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(tool_io|molecule|feature|primer|digest|pcr|run)[:/][A-Za-z0-9._:@#/?=-]+$"
      }
    },
    "feature_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "primer_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "export_path": {
      "type": "string",
      "minLength": 1
    }
  }
}
