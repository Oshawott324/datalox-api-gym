{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://datalox.local/schemas/env-data-proof-v0/split-metadata.schema.json",
  "title": "Datalox Env Data Proof Split Metadata",
  "description": "Deterministic split metadata for the seed-smoke post-training handoff.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "split_name",
    "split_kind",
    "created_at",
    "intended_use",
    "not_for",
    "policy",
    "counts",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "const": "agent_native_seed_split.v0"
    },
    "split_name": {
      "const": "seed-smoke"
    },
    "split_kind": {
      "const": "format_smoke_not_lift_proof"
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "intended_use": {
      "type": "string",
      "minLength": 1
    },
    "not_for": {
      "type": "string",
      "minLength": 1
    },
    "policy": {
      "type": "string",
      "minLength": 1
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "train",
        "dev",
        "test"
      ],
      "properties": {
        "train": {
          "type": "integer",
          "minimum": 1
        },
        "dev": {
          "type": "integer",
          "minimum": 1
        },
        "test": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "family",
          "split"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "family": {
            "type": "string",
            "enum": [
              "flowcyto",
              "molecule-biology",
              "scientific-data-qc"
            ]
          },
          "split": {
            "type": "string",
            "enum": [
              "train",
              "dev",
              "test"
            ]
          }
        }
      }
    }
  }
}
