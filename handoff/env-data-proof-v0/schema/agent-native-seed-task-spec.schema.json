{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://datalox.local/schemas/env-data-proof-v0/agent-native-seed-task-spec.schema.json",
  "title": "Datalox Env Data Proof Agent-Native Seed Task Spec",
  "description": "Task spec contract for the multi-family agent-native science seed handoff.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "family",
    "split",
    "task_family",
    "source_ref",
    "task_type",
    "expected_answer_class",
    "expected_failure_mode",
    "prompt",
    "output_schema",
    "family_output_schema",
    "allowed_tools",
    "forbidden_tools",
    "minimum_replayed_observations",
    "expected_tool_path",
    "success_criteria",
    "replay_capture_status"
  ],
  "properties": {
    "schema_version": {
      "const": "agent_native_seed_task_spec.v0"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "family": {
      "type": "string",
      "enum": [
        "flowcyto",
        "molecule-biology",
        "scientific-data-qc"
      ]
    },
    "split": {
      "type": "string",
      "enum": [
        "seed",
        "train",
        "dev",
        "test"
      ]
    },
    "task_family": {
      "type": "string",
      "minLength": 1
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "publication_status"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "repo_task_spec",
            "repo_fixture",
            "public_source_artifact"
          ]
        },
        "repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "task_path": {
          "type": "string",
          "minLength": 1
        },
        "fixture_path": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "type": "string",
          "pattern": "^https://"
        },
        "world_path": {
          "type": "string",
          "minLength": 1
        },
        "publication_status": {
          "type": "string",
          "enum": [
            "repo_fixture_needs_public_pin",
            "public_url_pinned",
            "public_url_needs_locked_derivation",
            "public_url_verified"
          ]
        }
      }
    },
    "task_type": {
      "type": "string",
      "minLength": 1
    },
    "expected_answer_class": {
      "type": "string",
      "minLength": 1
    },
    "expected_failure_mode": {
      "type": "string",
      "minLength": 1
    },
    "prompt": {
      "type": "string",
      "minLength": 40
    },
    "output_schema": {
      "type": "string",
      "pattern": "^\\.\\./\\.\\./\\.\\./\\.\\./schema/task-output\\.schema\\.json$"
    },
    "family_output_schema": {
      "type": "string",
      "pattern": "^\\.\\./\\.\\./\\.\\./\\.\\./schema/(flowcyto-task-output|molecule-biology-task-output|scientific-data-task-output)\\.schema\\.json$"
    },
    "allowed_tools": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_tools": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "minimum_replayed_observations": {
      "type": "integer",
      "minimum": 3
    },
    "expected_tool_path": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_error_or_recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "error_code",
        "recovery"
      ],
      "properties": {
        "error_code": {
          "type": "string",
          "minLength": 1
        },
        "recovery": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "replay_capture_status": {
      "const": "pending_step_3"
    }
  }
}
