{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://datalox.local/schemas/env-data-proof-v0/source-dataset-manifest.schema.json",
  "title": "Datalox Env Data Proof Source Dataset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated",
    "policy",
    "sources",
    "source_sets"
  ],
  "properties": {
    "schema_version": {
      "const": "source_dataset_manifest.v0"
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_artifact_default",
        "training_claim_gate",
        "recapture_rule"
      ],
      "properties": {
        "raw_artifact_default": {
          "type": "string",
          "minLength": 1
        },
        "training_claim_gate": {
          "type": "string",
          "minLength": 1
        },
        "recapture_rule": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "family",
          "name",
          "artifact_kind",
          "primary_url",
          "publication_tier",
          "license_status",
          "raw_artifact_policy",
          "pin",
          "verification",
          "proposed_task_ids",
          "notes"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
          },
          "family": {
            "type": "string",
            "enum": [
              "flowcyto",
              "molecule-biology",
              "protein-mcp"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "artifact_kind": {
            "type": "string",
            "minLength": 1
          },
          "primary_url": {
            "type": "string",
            "pattern": "^https://"
          },
          "companion_urls": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^https://"
            }
          },
          "publication_tier": {
            "type": "string",
            "enum": [
              "public_pinned",
              "public_versioned_database",
              "public_needs_locked_derivation"
            ]
          },
          "license_status": {
            "type": "string",
            "enum": [
              "artistic-2.0",
              "provider_terms_review_pending",
              "public_database_policy_review_pending",
              "raw_copy_license_review_pending"
            ]
          },
          "raw_artifact_policy": {
            "type": "string",
            "enum": [
              "link_only_publish_derived_observations",
              "copy_allowed_after_license_review",
              "cache_for_generation_do_not_publish_raw"
            ]
          },
          "pin": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "value"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "git_commit",
                  "accession_version",
                  "package_version",
                  "provider_record",
                  "http_headers"
                ]
              },
              "value": {
                "type": "string",
                "minLength": 1
              },
              "package_path": {
                "type": "string",
                "minLength": 1
              },
              "etag": {
                "type": "string",
                "minLength": 1
              },
              "content_length": {
                "type": "string",
                "pattern": "^\\d+$"
              },
              "last_modified": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "verification": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "method",
              "expected_status",
              "checked_at"
            ],
            "properties": {
              "method": {
                "type": "string",
                "enum": [
                  "head",
                  "get_headers"
                ]
              },
              "expected_status": {
                "type": "integer",
                "minimum": 100,
                "maximum": 599
              },
              "checked_at": {
                "type": "string",
                "format": "date-time"
              },
              "expected_content_type_prefix": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "proposed_task_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
            }
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source_sets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "set_id",
          "source_ids",
          "purpose"
        ],
        "properties": {
          "set_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
            }
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
