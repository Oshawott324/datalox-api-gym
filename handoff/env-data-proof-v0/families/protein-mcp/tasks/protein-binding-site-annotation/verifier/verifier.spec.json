{
  "schema_version": "agent_native_seed_verifier_spec.v0",
  "task_id": "protein-binding-site-annotation",
  "family": "protein-mcp",
  "output_schema": "../../../../schema/task-output.schema.json",
  "family_output_schema": "../../../../schema/protein-mcp-task-output.schema.json",
  "required": {
    "evidence_ids": [
      "tool_io:protein-binding-site-annotation/open_structure/0",
      "tool_io:protein-binding-site-annotation/list_ligands/1",
      "tool_io:protein-binding-site-annotation/annotate_binding_site/2",
      "tool_io:protein-binding-site-annotation/get_scene_annotations/3",
      "tool_io:protein-binding-site-annotation/validate_workspace/4"
    ],
    "captured_evidence_only": true
  },
  "family_output_checks": [
    {
      "path": "family_output.operation",
      "equals": "binding_site_annotation"
    },
    {
      "path": "family_output.structure_id",
      "equals": "target"
    },
    {
      "path": "family_output.workspace_revision",
      "equals": 1
    },
    {
      "path": "family_output.ligand_ids",
      "contains_all": [
        "HEM:A:142"
      ]
    },
    {
      "path": "family_output.view_id",
      "equals": "annotated_hem_a_142"
    }
  ]
}
