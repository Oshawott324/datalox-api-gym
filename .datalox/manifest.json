{
  "version": 1,
  "kind": "portable_knowledge_pack",
  "name": "Datalox Pack",
  "mode": "repo_only",
  "runtimeRequired": false,
  "configPath": ".datalox/config.json",
  "instructionPaths": [
    "DATALOX.md",
    "AGENTS.md",
    "CLAUDE.md",
    "WIKI.md",
    "GEMINI.md",
    ".github/copilot-instructions.md",
    ".cursor/rules/datalox-pack.mdc",
    ".windsurf/rules/datalox-pack.md"
  ],
  "entrypoints": {
    "seedSkillsDir": "skills",
    "seedNotesDir": "agent-wiki/notes",
    "hostSkillsDir": null,
    "hostNotesDir": null
  },
  "knowledgeModel": {
    "primaryDurableEntry": "skill",
    "supportingDurableEntry": "note",
    "normalReadPath": [
      "detect_skill",
      "read_skill",
      "read_linked_notes",
      "act"
    ],
    "noteLinkField": "metadata.datalox.note_paths"
  },
  "controlArtifacts": {
    "indexPath": "agent-wiki/index.md",
    "logPath": "agent-wiki/log.md",
    "lintPath": "agent-wiki/lint.md",
    "hotPath": "agent-wiki/hot.md"
  },
  "startup": {
    "readOnEveryLoop": true,
    "readOrder": [
      ".datalox/config.local.json",
      ".datalox/config.json",
      "DATALOX.md",
      "AGENTS.md",
      "CLAUDE.md",
      "WIKI.md",
      "GEMINI.md"
    ],
    "skillSelectionSignals": [
      "current task text",
      "current workflow if known",
      "git changed paths when available",
      "repo root files",
      "package metadata"
    ]
  },
  "agentRules": {
    "preserveNativeSkills": true,
    "generatedSkillsDir": "skills",
    "notesDir": "agent-wiki/notes",
    "knowledgeDirs": [
      "agent-wiki/notes"
    ],
    "hostRepoOwnsWrites": true
  },
  "distribution": {
    "oneClickBootstrap": "TARGET_REPO=\"$(pwd)\" && git clone https://github.com/Complexity-LLC/datalox-pack.git datalox-trajectory-mcp && cd datalox-trajectory-mcp && bash bin/setup-multi-agent.sh claude && bash bin/adopt-host-repo.sh \"$TARGET_REPO\" && node bin/datalox.js status --repo \"$TARGET_REPO\" --json",
    "multiAgentSetup": "bash bin/setup-multi-agent.sh claude",
    "friendlyEntryPoint": "START_HERE.md",
    "agentSetupPrompt": {
      "instruction": "Paste this into the agent chatbox from the repo you want Datalox to manage.",
      "commands": [
        "TARGET_REPO=\"$(pwd)\"",
        "git clone https://github.com/Complexity-LLC/datalox-pack.git datalox-trajectory-mcp",
        "cd datalox-trajectory-mcp",
        "bash bin/setup-multi-agent.sh claude",
        "bash bin/adopt-host-repo.sh \"$TARGET_REPO\"",
        "node bin/datalox.js status --repo \"$TARGET_REPO\" --json"
      ],
      "sourcePackRole": "The public GitHub source repo is datalox-pack; the local checkout/package identity is datalox-trajectory-mcp and it owns bin/adopt-host-repo.sh.",
      "targetRepoRole": "$TARGET_REPO is the user's current project and receives the Datalox install stamp, instruction surfaces, core skills, and notes."
    },
    "defaultBootstrapBundle": {
      "skills": [
        "skills/maintain-datalox-pack",
        "skills/use-datalox-through-host-cli"
      ],
      "notes": [
        "agent-wiki/notes/maintain-datalox-pack.md",
        "agent-wiki/notes/use-datalox-through-host-cli.md",
        "agent-wiki/notes/repo-engineering-multi-agent-bootstrap-surfaces.md"
      ]
    },
    "wrapperFallback": {
      "claude": "node bin/datalox-claude.js --repo <repo> -- --print \"<prompt>\"",
      "codex": "node bin/datalox-codex.js --repo <repo> --task \"<task>\" --prompt \"<prompt>\"",
      "genericCli": "node bin/datalox-wrap.js command --repo <repo> --task \"<task>\" --prompt \"<prompt>\" -- <host-command> __DATALOX_PROMPT__"
    }
  }
}
