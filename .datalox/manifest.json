{
  "version": 1,
  "kind": "trajectory_mcp_pack",
  "name": "Datalox Trajectory MCP",
  "mode": "repo_only",
  "runtimeRequired": false,
  "configPath": ".datalox/config.json",
  "instructionPaths": [
    "DATALOX.md",
    "AGENTS.md",
    "CLAUDE.md",
    "WIKI.md",
    "GEMINI.md",
    ".github/copilot-instructions.md",
    ".cursor/rules/datalox-pack.mdc",
    ".windsurf/rules/datalox-pack.md"
  ],
  "eventStores": {
    "agentTurns": ".datalox/events/agent-turns",
    "debuggingTrajectories": ".datalox/events/trajectory-rows",
    "agentTaskTrajectories": ".datalox/events/agent-task-trajectories",
    "sessionCandidates": ".datalox/session-candidates",
    "approvals": ".datalox/approvals"
  },
  "productModel": {
    "sourceAsset": "approved_anonymized_session_bundle",
    "capturePrimitive": "agent_turn.v1",
    "derivatives": [
      "debugging_trajectory.v1",
      "agent_task_trajectory.v1"
    ],
    "guidanceSurfaces": [
      "docs/",
      "DATALOX.md",
      "AGENTS.md",
      "skills/"
    ]
  },
  "startup": {
    "readOnEveryLoop": true,
    "readOrder": [
      ".datalox/config.local.json",
      ".datalox/config.json",
      "docs/product-definition.md",
      "DATALOX.md",
      "AGENTS.md",
      "CLAUDE.md",
      "WIKI.md",
      "GEMINI.md"
    ]
  },
  "distribution": {
    "oneClickBootstrap": "TARGET_REPO=\"$(pwd)\" && git clone https://github.com/Complexity-LLC/datalox-pack.git datalox-trajectory-mcp && cd datalox-trajectory-mcp && bash bin/setup-multi-agent.sh codex && bash bin/adopt-host-repo.sh \"$TARGET_REPO\" && node bin/datalox.js status --repo \"$TARGET_REPO\" --json",
    "multiAgentSetup": "bash bin/setup-multi-agent.sh codex",
    "friendlyEntryPoint": "START_HERE.md",
    "agentSetupPrompt": {
      "instruction": "Paste this into the agent chatbox from the repo you want Datalox to manage.",
      "commands": [
        "TARGET_REPO=\"$(pwd)\"",
        "git clone https://github.com/Complexity-LLC/datalox-pack.git datalox-trajectory-mcp",
        "cd datalox-trajectory-mcp",
        "bash bin/setup-multi-agent.sh codex",
        "bash bin/adopt-host-repo.sh \"$TARGET_REPO\"",
        "node bin/datalox.js status --repo \"$TARGET_REPO\" --json"
      ],
      "sourcePackRole": "The public GitHub source repo is datalox-pack; the local checkout/package identity is datalox-trajectory-mcp and it owns bin/adopt-host-repo.sh.",
      "targetRepoRole": "$TARGET_REPO is the user's current project and receives the Datalox install stamp, instruction surfaces, .datalox config, and host shims."
    },
    "defaultBootstrapBundle": {
      "eventsRoot": ".datalox/events",
      "instructionSurfaces": [
        "DATALOX.md",
        "AGENTS.md",
        "CLAUDE.md",
        "WIKI.md",
        "GEMINI.md"
      ]
    },
    "wrapperFallback": {
      "claude": "node bin/datalox-claude.js --repo <repo> -- --print \"<prompt>\"",
      "codex": "node bin/datalox-codex.js --repo <repo> --task \"<task>\" --prompt \"<prompt>\"",
      "genericCli": "node bin/datalox-wrap.js command --repo <repo> --task \"<task>\" --prompt \"<prompt>\" -- <host-command> __DATALOX_PROMPT__"
    }
  }
}
